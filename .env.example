# Truora (solo servidor; no uses prefijo VITE_)
# En local: copia a .env y rellena. En Vercel: Project Settings → Environment Variables.
TRUORA_ROOT_API_KEY=
TRUORA_FLOW_ID=
TRUORA_ACCOUNT_ID=

# API Key para envío de WhatsApp outbound (Truora Connect)
TRUORA_WHATSAPP_API_KEY=

# Opcional. Si no está definida, se usa https://hogarfix.vercel.app/gracias
# TRUORA_REDIRECT_URL=https://hogarfix.vercel.app/gracias
