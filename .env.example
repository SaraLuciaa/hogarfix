# Truora (solo servidor; no uses prefijo VITE_)
# En local: copia a .env y rellena. En Vercel: Project Settings → Environment Variables.
TRUORA_ROOT_API_KEY=
TRUORA_FLOW_ID=
TRUORA_ACCOUNT_ID=

# Opcional. Si no está definida, se usa la cabecera Origin del navegador + /callback
# TRUORA_REDIRECT_URL=https://tudominio.com/callback
